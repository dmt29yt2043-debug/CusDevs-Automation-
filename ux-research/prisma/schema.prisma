generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  scenarios   Scenario[]
  participants Participant[]
  sessions    Session[]
}

model Scenario {
  id             String    @id @default(uuid())
  projectId      String
  name           String
  version        Int       @default(1)
  definitionJson Json
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project   @relation(fields: [projectId], references: [id])
  sessions       Session[]

  @@index([projectId])
}

model Participant {
  id                  String    @id @default(uuid())
  projectId           String
  externalId          String?
  source              String?
  email               String?
  screenerAnswersJson Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  project             Project   @relation(fields: [projectId], references: [id])
  sessions            Session[]

  @@index([projectId])
}

enum SessionStatus {
  started
  in_progress
  completed
  abandoned
}

model Session {
  id            String        @id @default(uuid())
  projectId     String
  scenarioId    String
  participantId String?
  status        SessionStatus @default(started)
  startedAt     DateTime      @default(now())
  endedAt       DateTime?
  durationSec   Int?
  metadataJson  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  project       Project       @relation(fields: [projectId], references: [id])
  scenario      Scenario      @relation(fields: [scenarioId], references: [id])
  participant   Participant?  @relation(fields: [participantId], references: [id])
  events        Event[]
  responses     Response[]
  audioAssets   AudioAsset[]

  @@index([projectId])
  @@index([scenarioId])
  @@index([participantId])
}

model Event {
  id              String   @id @default(uuid())
  sessionId       String
  eventType       String
  pageUrl         String?
  elementSelector String?
  x               Float?
  y               Float?
  payloadJson     Json?
  createdAt       DateTime @default(now())
  session         Session  @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([eventType])
}

enum ResponseType {
  rating
  text
  choice
  audio
}

model Response {
  id           String       @id @default(uuid())
  sessionId    String
  stepId       String
  responseType ResponseType
  valueJson    Json
  createdAt    DateTime     @default(now())
  session      Session      @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model AudioAsset {
  id          String   @id @default(uuid())
  sessionId   String
  stepId      String
  filePath    String
  mimeType    String?
  durationSec Float?
  transcript  String?
  createdAt   DateTime @default(now())
  session     Session  @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}
